{
  "name": "@princy/memory-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import ../../packages/service-kit/load-env.mjs dist/index.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@princy/ai-client": "*",
    "@princy/core": "*",
    "@princy/database": "*",
    "@princy/event-bus": "*",
    "@princy/memory": "*",
    "@princy/model-router": "*",
    "@princy/service-kit": "*",
    "dotenv": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "tsx": "latest"
  }
}
