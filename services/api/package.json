{
  "name": "@princy/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --import ../../packages/service-kit/load-env.mjs dist/index.js",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@princy/core": "*",
    "@princy/database": "*",
    "@princy/service-kit": "*",
    "bcryptjs": "latest",
    "express": "latest",
    "jsonwebtoken": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/supertest": "latest",
    "supertest": "latest"
  }
}
