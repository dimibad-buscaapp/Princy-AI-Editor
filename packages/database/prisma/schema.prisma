generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AgentType {
  AUTO
  PLANNER
  CODER
  REVIEWER
  DEBUGGER
  ARCHITECT
  TERMINAL
}

enum AgentStatus {
  IDLE
  RUNNING
  FAILED
  COMPLETED
}

enum TaskStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
  CANCELLED
}

enum MemoryScope {
  USER
  PROJECT
  CONVERSATION
  WORKSPACE
  AGENT
  TEAM
}

enum AgentMemoryKind {
  decision
  error
  preference
  context
}

enum CodeMemoryKind {
  SYMBOL
  ROUTE
  ENDPOINT
  PRISMA_MODEL
  PACKAGE
  FILE
}

enum SwarmAgentRole {
  COORDINATOR
  ARCHITECT
  DEVELOPER
  TESTER
  REVIEWER
  DEVOPS
}

enum PatchStatus {
  PROPOSED
  APPLIED
  ROLLED_BACK
  FAILED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AutonomousGoalStatus {
  PENDING
  PLANNING
  EXECUTING
  AWAITING_APPROVAL
  COMPLETED
  FAILED
  CANCELLED
}

enum ModelSlot {
  CHAT
  EDITOR
  SWARM
  AUTONOMOUS
  EMBED
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  role         UserRole      @default(DEVELOPER)
  projects     Project[]
  memoryChunks MemoryChunk[]
  auditLogs    AuditLog[]
  patches      Patch[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  teams     Team[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

model Team {
  id           String        @id @default(cuid())
  orgId        String
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  slug         String
  members      TeamMember[]
  memoryChunks MemoryChunk[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([orgId, slug])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  role      String   @default("developer")
  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

model Project {
  id            String              @id @default(cuid())
  name          String
  description   String?
  ownerId       String
  teamId        String?
  owner         User                @relation(fields: [ownerId], references: [id])
  workspaces    Workspace[]
  conversations Conversation[]
  memoryChunks  MemoryChunk[]
  contextNodes  ContextNode[]
  patches       Patch[]
  goals         AutonomousGoal[]
  projectMemory ProjectMemory?
  codeMemories  CodeMemory[]
  chatCache     ChatCacheEntry[]
  permissions   ProjectPermission[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([ownerId])
}

model ProjectPermission {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  capability String
  grantedBy  String?
  createdAt  DateTime @default(now())

  @@unique([projectId, userId, capability])
  @@index([projectId])
  @@index([userId])
}

model Workspace {
  id           String          @id @default(cuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path         String
  memoryChunks MemoryChunk[]
  patches      Patch[]
  profile      WorkspaceProfile?
  codeMemories CodeMemory[]
  locks        WorkspaceLock[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([projectId])
}

model WorkspaceLock {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  filePath    String
  userId      String
  userName    String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  @@unique([workspaceId, filePath])
  @@index([workspaceId])
  @@index([expiresAt])
}

model Conversation {
  id           String        @id @default(cuid())
  projectId    String?
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  messages     Message[]
  memoryChunks MemoryChunk[]
  memory       ConversationMemory?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([projectId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([role])
}

model Agent {
  id         String           @id @default(cuid())
  name       String
  type       AgentType
  status     AgentStatus      @default(IDLE)
  tasks      Task[]
  executions AgentExecution[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([type])
  @@index([status])
}

model Task {
  id          String           @id @default(cuid())
  agentId     String?
  agent       Agent?           @relation(fields: [agentId], references: [id], onDelete: SetNull)
  title       String
  status      TaskStatus       @default(PENDING)
  payload     Json?
  result      Json?
  executions  AgentExecution[]
  goalId      String?
  goal        AutonomousGoal?  @relation(fields: [goalId], references: [id], onDelete: SetNull)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([agentId])
  @@index([status])
  @@index([goalId])
}

model AgentExecution {
  id         String      @id @default(cuid())
  agentId    String
  agent      Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  taskId     String?
  task       Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)
  input      Json?
  output     Json?
  status     TaskStatus  @default(RUNNING)
  durationMs Int?
  createdAt  DateTime    @default(now())

  @@index([agentId])
  @@index([taskId])
  @@index([status])
}

model MemoryChunk {
  id             String       @id @default(cuid())
  scope          MemoryScope  @default(PROJECT)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  workspaceId    String?
  workspace      Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  title          String?
  content        String
  tags           Json?
  metadata       Json?
  embeddings     Embedding[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([projectId, scope])
  @@index([teamId, scope])
  @@index([conversationId])
  @@index([userId])
  @@index([workspaceId])
}

model Embedding {
  id            String                      @id @default(cuid())
  memoryChunkId String
  memoryChunk   MemoryChunk                 @relation(fields: [memoryChunkId], references: [id], onDelete: Cascade)
  vector        Unsupported("vector(768)")?
  model         String
  dimensions    Int
  createdAt     DateTime                    @default(now())

  @@index([memoryChunkId])
  @@index([model])
}

model ContextNode {
  id            String        @id @default(cuid())
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type          String
  name          String
  path          String?
  metadata      Json?
  outgoingEdges ContextEdge[] @relation("ContextEdgeSource")
  incomingEdges ContextEdge[] @relation("ContextEdgeTarget")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([path])
}

model ContextEdge {
  id           String      @id @default(cuid())
  sourceId     String
  targetId     String
  source       ContextNode @relation("ContextEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       ContextNode @relation("ContextEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  relationship String
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([sourceId])
  @@index([targetId])
  @@index([relationship])
}

model Patch {
  id          String       @id @default(cuid())
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  filePath    String
  diff        String
  status      PatchStatus  @default(PROPOSED)
  backupPath  String?
  appliedAt   DateTime?
  history     PatchHistory[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([projectId])
  @@index([status])
}

model PatchHistory {
  id        String   @id @default(cuid())
  patchId   String
  patch     Patch    @relation(fields: [patchId], references: [id], onDelete: Cascade)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([patchId])
}

model TerminalSession {
  id          String   @id @default(cuid())
  workspaceId String?
  cwd         String?
  history     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AutonomousGoal {
  id          String               @id @default(cuid())
  projectId   String?
  project     Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title       String
  description String?
  status      AutonomousGoalStatus @default(PENDING)
  payload     Json?
  result      Json?
  tasks       Task[]
  approvals   ApprovalRequest[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([projectId])
  @@index([status])
}

model ApprovalRequest {
  id        String         @id @default(cuid())
  goalId    String?
  goal      AutonomousGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)
  patchId   String?
  type      String
  status    ApprovalStatus @default(PENDING)
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([goalId])
  @@index([status])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}

model ModelAssignment {
  slot      ModelSlot @id
  modelId   String
  updatedAt DateTime  @updatedAt
  updatedBy String?
}

model ModelMetric {
  id           String   @id @default(cuid())
  modelId      String
  task         String
  ttftMs       Int
  totalMs      Int
  tokenCount   Int
  tokensPerSec Float
  cacheHit     Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([modelId, createdAt])
  @@index([task, createdAt])
}

model ProjectMemory {
  id                  String   @id @default(cuid())
  projectId           String   @unique
  project             Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                String?
  stack               Json?
  services            Json?
  ports               Json?
  routes              Json?
  recentChanges       Json?
  pending             Json?
  technicalDecisions  Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ConversationMemory {
  id               String       @id @default(cuid())
  conversationId   String       @unique
  conversation     Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  shortSummary     String?
  longSummary      String?
  userPreferences  Json?
  lastSummarizedAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model CodeMemory {
  id          String         @id @default(cuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  filePath    String
  kind        CodeMemoryKind
  symbol      String?
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId, kind])
  @@index([workspaceId])
  @@index([filePath])
}

model AgentMemory {
  id            String           @id @default(cuid())
  agentRole     String
  kind          AgentMemoryKind  @default(decision)
  projectId     String?
  content       String?
  recurrenceKey String?
  taskId        String?
  success       Boolean          @default(true)
  durationMs    Int?
  decision      String?
  metadata      Json?
  createdAt     DateTime         @default(now())

  @@index([agentRole])
  @@index([taskId])
  @@index([projectId])
  @@index([kind])
  @@index([recurrenceKey])
}

model ChatCacheEntry {
  id         String   @id @default(cuid())
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  queryHash  String
  query      String
  response   String
  model      String
  ttlSeconds Int      @default(86400)
  hitCount   Int      @default(0)
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([queryHash, projectId])
  @@index([expiresAt])
}

model SwarmRun {
  id           String          @id @default(cuid())
  objective    String
  context      String?
  status       TaskStatus      @default(PENDING)
  currentAgent SwarmAgentRole?
  progress     Int             @default(0)
  pipelineId   String          @unique
  artifacts    Json?
  startedAt    DateTime?
  completedAt  DateTime?
  durationMs   Int?
  error        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
}

model SwarmTask {
  id           String         @id @default(cuid())
  pipelineId   String
  parentTaskId String?
  parent       SwarmTask?     @relation("SwarmSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  children     SwarmTask[]    @relation("SwarmSubtasks")
  title        String
  description  String?
  agentRole    SwarmAgentRole
  status       TaskStatus     @default(PENDING)
  input        Json?
  output       Json?
  logs         Json?
  order        Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([pipelineId])
  @@index([parentTaskId])
  @@index([status])
  @@index([agentRole])
}

model WorkspaceProfile {
  id             String    @id @default(cuid())
  workspaceId    String    @unique
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  framework      String?
  language       String?
  packageManager String?
  services       Json?
  ports          Json?
  scripts        Json?
  database       Json?
  deployment     Json?
  risks          Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model InstalledAgent {
  id         String   @id @default(cuid())
  userId     String
  agentId    String
  version    String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@unique([userId, agentId])
  @@index([userId])
}

model InstalledItem {
  id        String   @id @default(cuid())
  userId    String
  itemType  String
  itemId    String
  version   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@unique([userId, itemType, itemId])
  @@index([userId, itemType])
}

model AutonomousProject {
  id               String   @id @default(cuid())
  title            String
  objective        String
  description      String?
  projectId        String?
  status           TaskStatus @default(PENDING)
  milestones       Json?
  blockers         Json?
  currentMilestone Int      @default(0)
  metadata         Json?
  runs             AutonomousProjectRun[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([projectId])
}

model AutonomousProjectRun {
  id          String            @id @default(cuid())
  projectId   String
  project     AutonomousProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      TaskStatus        @default(PENDING)
  result      Json?
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime          @default(now())

  @@index([projectId])
}

model SyncState {
  id            String   @id @default(cuid())
  userId        String
  entity        String
  entityId      String
  localVersion  DateTime
  remoteVersion DateTime
  checksum      String?
  status        String   @default("synced")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, entity, entityId])
  @@index([userId])
}

model SyncQueue {
  id        String   @id @default(cuid())
  userId    String
  entity    String
  entityId  String
  operation String
  payload   Json
  attempts  Int      @default(0)
  status    String   @default("pending")
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([createdAt])
}

model TaskPattern {
  id              String   @id @default(cuid())
  patternKey      String   @unique
  label           String
  category        String
  occurrenceCount Int      @default(1)
  template        Json?
  lastPlan        Json?
  projectId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([projectId])
  @@index([occurrenceCount])
}

