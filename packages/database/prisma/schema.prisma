generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AgentType {
  AUTO
  PLANNER
  CODER
  REVIEWER
  DEBUGGER
  ARCHITECT
  TERMINAL
}

enum AgentStatus {
  IDLE
  RUNNING
  FAILED
  COMPLETED
}

enum TaskStatus {
  PENDING
  RUNNING
  FAILED
  COMPLETED
  CANCELLED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole   @default(DEVELOPER)
  projects     Project[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id            String         @id @default(cuid())
  name          String
  description   String?
  ownerId       String
  owner         User           @relation(fields: [ownerId], references: [id])
  workspaces    Workspace[]
  conversations Conversation[]
  memoryChunks  MemoryChunk[]
  contextNodes  ContextNode[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
}

model Workspace {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Conversation {
  id        String    @id @default(cuid())
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title     String
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([role])
}

model Agent {
  id        String      @id @default(cuid())
  name      String
  type      AgentType
  status    AgentStatus @default(IDLE)
  tasks     Task[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([type])
  @@index([status])
}

model Task {
  id        String     @id @default(cuid())
  agentId   String?
  agent     Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  title     String
  status    TaskStatus @default(PENDING)
  payload   Json?
  result    Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([agentId])
  @@index([status])
}

model MemoryChunk {
  id         String      @id @default(cuid())
  projectId  String?
  project    Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  content    String
  metadata   Json?
  embeddings Embedding[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([projectId])
}

model Embedding {
  id                String      @id @default(cuid())
  memoryChunkId     String
  memoryChunk   MemoryChunk @relation(fields: [memoryChunkId], references: [id], onDelete: Cascade)
  vectorUnsupported String?
  model         String
  dimensions    Int
  createdAt     DateTime    @default(now())

  @@index([memoryChunkId])
  @@index([model])
}

model ContextNode {
  id            String        @id @default(cuid())
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  type          String
  name          String
  path          String?
  metadata      Json?
  outgoingEdges ContextEdge[] @relation("ContextEdgeSource")
  incomingEdges ContextEdge[] @relation("ContextEdgeTarget")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([path])
}

model ContextEdge {
  id           String      @id @default(cuid())
  sourceId     String
  targetId     String
  source       ContextNode @relation("ContextEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target       ContextNode @relation("ContextEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)
  relationship String
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([sourceId])
  @@index([targetId])
  @@index([relationship])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
}
