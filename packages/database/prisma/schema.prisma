generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  DEVELOPER
  VIEWER
}

enum AgentKind {
  AUTO
  PLANNER
  CODER
  REVIEWER
  DEBUGGER
  ARCHITECT
  TERMINAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  passwordHash String?
  role         UserRole   @default(DEVELOPER)
  projects     Project[]
  workspaces   Workspace[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id            String         @id @default(uuid())
  name          String
  description   String?
  ownerId       String?
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  workspaces    Workspace[]
  conversations Conversation[]
  tasks         Task[]
  memories      MemoryChunk[]
  contextNodes  ContextNode[]
  auditLogs     AuditLog[]
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([ownerId])
}

model Workspace {
  id            String         @id @default(uuid())
  name          String
  rootPath      String?
  projectId     String?
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ownerId       String?
  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  conversations Conversation[]
  tasks         Task[]
  metadata      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

model Conversation {
  id          String    @id @default(uuid())
  title       String
  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  messages    Message[]
  memories    MemoryChunk[]
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([workspaceId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model Agent {
  id          String    @id @default(uuid())
  kind        AgentKind @unique
  name        String
  description String?
  enabled     Boolean   @default(true)
  tasks       Task[]
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  agentId     String?
  agent       Agent?     @relation(fields: [agentId], references: [id], onDelete: SetNull)
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([workspaceId])
  @@index([agentId])
}

model MemoryChunk {
  id             String        @id @default(uuid())
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  sourceType     String
  sourceId       String?
  content        String
  metadata       Json?
  embedding      Embedding?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([projectId])
  @@index([conversationId])
  @@index([sourceType])
}

model Embedding {
  id            String      @id @default(uuid())
  memoryChunkId String      @unique
  memoryChunk   MemoryChunk @relation(fields: [memoryChunkId], references: [id], onDelete: Cascade)
  model         String
  dimensions    Int
  vector        Float[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ContextNode {
  id          String        @id @default(uuid())
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type        String
  name        String
  filePath    String?
  startLine   Int?
  endLine     Int?
  metadata    Json?
  outgoing    ContextEdge[] @relation("ContextEdgeSource")
  incoming    ContextEdge[] @relation("ContextEdgeTarget")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([projectId])
  @@index([type])
  @@index([filePath])
}

model ContextEdge {
  id           String      @id @default(uuid())
  sourceNodeId String
  sourceNode   ContextNode @relation("ContextEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNodeId String
  targetNode   ContextNode @relation("ContextEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)
  type         String
  metadata     Json?
  createdAt    DateTime    @default(now())

  @@index([sourceNodeId])
  @@index([targetNodeId])
  @@index([type])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([projectId])
  @@index([entity])
}
