{
  "name": "@princy/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prisma:generate": "node scripts/with-database-url.mjs prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "typecheck": "npm run prisma:generate && tsc --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest"
  },
  "devDependencies": {
    "prisma": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
