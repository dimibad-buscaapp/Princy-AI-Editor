{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MarketplaceManifest",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "name", "description", "version"],
        "properties": {
          "id": { "type": "string" },
          "type": { "enum": ["agent", "template", "mcp", "theme", "tool"] },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "category": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "version": { "type": "string" },
          "author": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
