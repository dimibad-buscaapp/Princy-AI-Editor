########################################
# JWT (PHASE 4)
########################################

JWT_SECRET=GERAR_SECRET_64_CARACTERES
JWT_REFRESH_SECRET=GERAR_REFRESH_SECRET_64_CARACTERES
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

########################################
# PASSWORD HASH
########################################

