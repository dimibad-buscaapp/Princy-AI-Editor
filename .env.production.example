AGENT_TIMEOUT_MS=300000
AGENT_MAX_RETRIES=3

########################################
# AUTOMATION
########################################

AUTOMATION_MAX_CONCURRENT_JOBS=10

########################################
# MCP
########################################

MCP_ENABLED=true

########################################
# VERSION
########################################

PRINCY_VERSION=0.3.0
