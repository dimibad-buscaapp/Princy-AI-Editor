GATEWAY_PROXY_TIMEOUT_MS=10000
GATEWAY_HEALTH_TIMEOUT_MS=1500
GATEWAY_CIRCUIT_BREAKER_FAILURES=5
GATEWAY_CIRCUIT_BREAKER_RESET_MS=30000
