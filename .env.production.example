########################################
# PRINCY AI EDITOR — VPS PRODUCTION
# Path: C:\Apps\Princy-Ai-Editor
# IP:   108.181.169.40
#
# Setup (PowerShell Admin on VPS):
#   powershell -ExecutionPolicy Bypass -File scripts\windows\setup-production-env.ps1
########################################

APP_NAME=Princy AI Editor
APP_ENV=production
NODE_ENV=production
HOST=0.0.0.0

########################################
# VPS
########################################

VPS_IP=108.181.169.40

########################################
# PORTS (do not change without firewall update)
########################################

FRONTEND_PORT=3400
API_PORT=3401
AGENTS_PORT=3402
WORKSPACE_SERVICE_PORT=3403
WORKSPACE_PORT=3403
CONTEXT_GRAPH_PORT=3404
MEMORY_SERVICE_PORT=3405
MEMORY_PORT=3405
AUTOMATION_SERVICE_PORT=3406
AUTOMATION_PORT=3406
GATEWAY_PORT=3407
MCP_SERVER_PORT=3408
MCP_PORT=3408
FUTURE_PORT=3409

########################################
# INTERNAL URLS (gateway -> services on localhost)
########################################

FRONTEND_URL=http://127.0.0.1:3400
API_URL=http://127.0.0.1:3401
AGENTS_URL=http://127.0.0.1:3402
WORKSPACE_SERVICE_URL=http://127.0.0.1:3403
CONTEXT_GRAPH_URL=http://127.0.0.1:3404
MEMORY_SERVICE_URL=http://127.0.0.1:3405
AUTOMATION_SERVICE_URL=http://127.0.0.1:3406
GATEWAY_URL=http://127.0.0.1:3407
MCP_SERVER_URL=http://127.0.0.1:3408

########################################
# PUBLIC URLS (browser / NEXT_PUBLIC_*)
########################################

PUBLIC_FRONTEND_URL=http://108.181.169.40:3400
PUBLIC_GATEWAY_URL=http://108.181.169.40:3407
NEXT_PUBLIC_GATEWAY_URL=http://108.181.169.40:3407
NEXT_PUBLIC_API_BASE_URL=http://108.181.169.40:3407/api

########################################
# POSTGRESQL (server on port 5432 = PostgreSQL 17 on this VPS)
########################################

DATABASE_URL=postgresql://postgres:CHANGE_ME_DB_PASSWORD@localhost:5432/princy_ai_editor

########################################
# LOGS (absolute path recommended on VPS)
########################################

LOG_LEVEL=info
PRINCY_LOG_DIR=C:\Apps\Princy-Ai-Editor\logs

########################################
# CORS
########################################

CORS_ORIGINS=http://localhost:3400,http://127.0.0.1:3400,http://108.181.169.40:3400
GATEWAY_CORS_ORIGINS=http://localhost:3400,http://127.0.0.1:3400,http://108.181.169.40:3400
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id,Accept
GATEWAY_CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-Id,Accept

########################################
# GATEWAY
########################################

GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_MAX=300
GATEWAY_PROXY_TIMEOUT_MS=300000
GATEWAY_HEALTH_TIMEOUT_MS=1500
GATEWAY_CIRCUIT_BREAKER_FAILURES=5
GATEWAY_CIRCUIT_BREAKER_RESET_MS=30000
GATEWAY_EXPOSE_INTERNAL_URLS=false

########################################
# JWT — generated by setup-production-env.ps1 if placeholders remain
########################################

JWT_SECRET=CHANGE_ME_JWT_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_JWT_REFRESH_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

########################################
# PASSWORD HASH
########################################

BCRYPT_ROUNDS=12

########################################
# OLLAMA (required for chat/embeddings)
########################################

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434
# VPS 8GB RAM: use modelos pequenos (qwen3-coder precisa ~18GB)
OLLAMA_CHAT_MODEL=qwen3:8b
DEFAULT_CHAT_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768
OLLAMA_TIMEOUT_MS=300000
AI_CLIENT_TIMEOUT_MS=300000
AGENTS_TIMEOUT_MS=300000
MODEL_ROUTER_TIMEOUT_MS=300000

########################################
# MEMORY SERVICE (pgvector)
########################################

MEMORY_MAX_RESULTS=20
MEMORY_DEFAULT_NAMESPACE=global
MEMORY_HYBRID_VECTOR_WEIGHT=0.7
MEMORY_HYBRID_TEXT_WEIGHT=0.3
MEMORY_REINDEX_BATCH=50
MEMORY_AUTO_EMBED=false

########################################
# CONTEXT GRAPH
########################################

CONTEXT_GRAPH_MAX_NODES=10000
CONTEXT_GRAPH_MAX_EDGES=50000

########################################
# AGENTS
########################################

DEFAULT_AGENT=AUTO
AGENT_TIMEOUT_MS=300000
AGENT_MAX_RETRIES=3

########################################
# AUTOMATION
########################################

AUTOMATION_MAX_CONCURRENT_JOBS=10

########################################
# MCP
########################################

MCP_ENABLED=true

########################################
# VERSION
########################################

PRINCY_VERSION=0.3.0
