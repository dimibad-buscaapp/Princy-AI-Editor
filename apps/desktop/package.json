{
  "name": "@princy/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Princy AI Editor — Electron desktop shell",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "pack": "npm run build && electron-builder --win",
    "start": "electron dist/main.js"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "tsx": "latest",
    "typescript": "latest"
  },
  "build": {
    "appId": "com.princy.ai-editor",
    "productName": "Princy AI Editor",
    "directories": { "output": "release" },
    "win": {
      "target": ["nsis"],
      "artifactName": "Princy-AI-Setup.${ext}"
    },
    "publish": [
      { "provider": "github", "owner": "princy", "repo": "Princy-AI-Editor" }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
