{
  "name": "@princy/desktop",
  "version": "1.0.0",
  "private": true,
  "author": "Princy AI",
  "description": "Princy Code — Electron desktop shell",
  "main": "out/main.js",
  "scripts": {
    "dev": "npm run build && cross-env PRINCY_DEV=1 electron .",
    "build": "tsc -p tsconfig.json",
    "start": "electron out/main.js",
    "dist": "npm run build && electron-builder --win nsis",
    "pack": "npm run build && electron-builder --dir",
    "pack:win": "npm run build && electron-builder --win nsis",
    "pack:linux": "npm run build && electron-builder --linux dir"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/node": "latest",
    "cross-env": "latest",
    "electron": "34.5.8",
    "electron-builder": "25.1.8",
    "typescript": "latest"
  }
}
