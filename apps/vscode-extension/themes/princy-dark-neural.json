    "activityBar.background": "#050816",
    "activityBar.foreground": "#8B5CF6",
    "activityBarBadge.background": "#622AF3",
    "statusBar.background": "#050816",
    "statusBar.foreground": "#22D3EE",
    "titleBar.activeBackground": "#020617",
    "titleBar.activeForeground": "#F8FAFC",
    "panel.background": "#050816",
    "terminal.background": "#020617",
    "focusBorder": "#622AF3",
    "button.background": "#622AF3",
    "button.foreground": "#F8FAFC",
    "list.activeSelectionBackground": "#622AF340",
    "list.hoverBackground": "#3B82F620"
